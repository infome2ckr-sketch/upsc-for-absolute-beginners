<script>
const slides = Array.from(document.querySelectorAll('.slide'));
const counter = document.getElementById('counter');
const progress = document.getElementById('progress');
const prevBtn = document.getElementById('prev');
const nextBtn = document.getElementById('next');

let currentSlide = 0;
let fragIndex = 0;
let timer = null;
const FRAG_DELAY = 800;
const SLIDE_HOLD = 2000;
let playing = true;

function getFragments(slide) { return Array.from(slide.querySelectorAll('.fragment')); }

function showSlide(idx) {
  if (idx < 0 || idx >= slides.length) return;
  clearTimeout(timer);
  slides.forEach(s => s.classList.remove('active'));
  currentSlide = idx;
  const slide = slides[currentSlide];
  slide.classList.add('active');
  getFragments(slide).forEach(f => f.classList.remove('visible'));
  fragIndex = 0;
  counter.textContent = `${currentSlide + 1} / ${slides.length}`;
  updateProgress(true);
  if (playing) timer = setTimeout(playFragment, 300);
}

function playFragment() {
  const frags = getFragments(slides[currentSlide]);
  if (fragIndex < frags.length) {
    frags[fragIndex].classList.add('visible');
    fragIndex++;
    updateProgress();
    timer = setTimeout(playFragment, FRAG_DELAY);
  } else {
    updateProgress();
    if (currentSlide < slides.length - 1 && playing) {
      timer = setTimeout(() => showSlide(currentSlide + 1), SLIDE_HOLD);
    } else {
      playing = false;
    }
  }
}

function next() { showSlide(Math.min(currentSlide + 1, slides.length - 1)); }
function prev() { showSlide(Math.max(currentSlide - 1, 0)); }

function updateProgress(immediate = false) {
  const totalFrags = slides.reduce((sum, s) => sum + getFragments(s).length, 0);
  const doneBefore = slides.slice(0, currentSlide).reduce((sum, s) => sum + getFragments(s).length, 0);
  const done = doneBefore + fragIndex;
  const pct = Math.max(2, (done / totalFrags) * 100);
  if (immediate) progress.style.transition = 'none';
  progress.style.width = pct + '%';
  if (immediate) { void progress.offsetWidth; progress.style.transition = 'width 0.5s linear'; }
}

// Controls
nextBtn.addEventListener('click', next);
prevBtn.addEventListener('click', prev);
document.addEventListener('keydown', e => {
  if (['ArrowRight',' '].includes(e.key)) { e.preventDefault(); next(); }
  if (e.key === 'ArrowLeft') { e.preventDefault(); prev(); }
});
document.getElementById('deck').addEventListener('click', e => {
  if (e.target.closest('button')) return;
  next();
});

// Start
showSlide(0);
</script>
