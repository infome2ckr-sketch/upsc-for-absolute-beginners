    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chinju — UPSC for Absolute Beginners</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Syne:wght@600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg: #030308;
            --glass: rgba(255, 255, 255, 0.04);
            --glass-border: rgba(255, 255, 255, 0.08);
            --text: #e8ee;
            --text-dim: #9a9aac;
            --purple: #8b5cf6;
            --pink: #ec4899;
            --blue: #22d3ee;
            --magenta: #d946ef;
        }

        html, body {
            height: 100%;
            overflow: hidden;
            background: var(--bg);
            color: var(--text);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        /* Background Blobs */
        .bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            overflow: hidden;
        }

        .blob {
            position: absolute;
            width: 60vmax;
            height: 60vmax;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.25;
            animation: float 40s infinite ease-in-out alternate;
        }

        .blob-1 {
            background: radial-gradient(circle, var(--purple), transparent 60%);
            top: -20%;
            left: -20%;
            animation-delay: 0s;
        }
        .blob-2 {
            background: radial-gradient(circle, var(--magenta), transparent 60%);
            top: -10%;
            right: -25%;
            animation-delay: -10s;
        }
        .blob-3 {
            background: radial-gradient(circle, var(--blue), transparent 60%);
            bottom: -30%;
            left: 10%;
            animation-delay: -20s;
        }
        .blob-4 {
            background: radial-gradient(circle, #3b82f6, transparent 60%);
            bottom: -20%;
            right: -10%;
            animation-delay: -30s;
        }

        @keyframes float {
            0% { transform: translate(0, 0) scale(1) rotate(0deg); }
            100% { transform: translate(5vw, -5vh) scale(1.1) rotate(20deg); }
        }

        /* Text & element animations */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes gentleFloat {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        @keyframes shimmer {
            0% { background-position: -200% center; }
            100% { background-position: 200% center; }
        }

        @keyframes pulseGlow {
            0%, 100% { box-shadow: 0 0 0 0 rgba(139,92,246,0); }
            50% { box-shadow: 0 0 30px 0 rgba(139,92,246,0.15); }
        }


        /* Progress */
        .progress {
            position: fixed;
            top: 0;
            left: 0;
            height: 2px;
            width: 0%;
            background: linear-gradient(90deg, var(--pink), var(--purple), var(--blue));
            z-index: 100;
            transition: width 0.1s linear;
        }

        /* Watermark */
        .watermark {
            position: fixed;
            left: 22px;
            bottom: 50%;
            transform: translateY(50%) rotate(-90deg);
            transform-origin: left center;
            font-size: 11px;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--text-dim);
            opacity: 0.5;
            z-index: 50;
            pointer-events: none;
            font-weight: 500;
        }

        /* Scroll Container */
        .snap {
            position: relative;
            z-index: 10;
            height: 100vh;
            overflow-y: scroll;
            overflow-x: hidden;
            scroll-snap-type: y mandatory;
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
        }

        section {
            height: 100vh;
            width: 100%;
            scroll-snap-align: start;
            scroll-snap-stop: always;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            position: relative;
        }

        .container {
            width: 100%;
            max-width: 900px;
            margin: 0 auto;
            text-align: center;
        }

        /* Glass */
        .glass {
            background: var(--glass);
            backdrop-filter: blur(24px) saturate(120%);
            -webkit-backdrop-filter: blur(24px) saturate(120%);
            border: 1px solid var(--glass-border);
        }

        /* Typography */
        h1 {
            font-family: 'Syne', sans-serif;
            font-size: clamp(3rem, 8vw, 5.5rem);
            font-weight: 700;
            letter-spacing: -0.02em;
            line-height: 1;
            margin-bottom: 1.5rem;
            background: linear-gradient(180deg, #fff 20%, #c7c7d1 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        h2 {
            font-family: 'Syne', sans-serif;
            font-size: clamp(2.2rem, 6vw, 3.75rem);
            font-weight: 700;
            letter-spacing: -0.02em;
            line-height: 1.1;
            margin-bottom: 1rem;
            color: #fff;
        }

        h3 {
            font-size: clamp(1.4rem, 3vw, 1.9rem);
            font-weight: 600;
            line-height: 1.3;
            margin-bottom: 0.75rem;
            color: #fff;
        }

        p {
            font-size: clamp(1rem, 2vw, 1.15rem);
            line-height: 1.6;
            color: var(--text-dim);
            max-width: 650px;
            margin: 0 auto;
        }

        /* Hero */
        .typewriter {
            font-size: clamp(1.1rem, 2.2vw, 1.35rem);
            color: var(--text);
            min-height: 2.2em;
            margin-bottom: 2.5rem;
            font-weight: 400;
        }

        .typewriter::after {
            content: '|';
            animation: blink 1s infinite;
            margin-left: 2px;
            color: var(--purple);
        }

        @keyframes blink { 0%,50% {opacity:1} 51%,100% {opacity:0} }

        .stats {
            display: flex;
            gap: 1rem;
            justify-content: center;
            margin-bottom: 2rem;
        }

        .stat {
            padding: 0.9rem 1.5rem;
            border-radius: 16px;
            font-size: 1.1rem;
            font-weight: 600;
            color: #fff;
            min-width: 110px;
        }

        .stat span {
            display: block;
            font-size: 0.7rem;
            font-weight: 500;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-top: 0.15rem;
        }

        .tiny {
            font-size: 0.95rem;
            color: var(--text-dim);
            opacity: 0.8;
        }

        /* Question */
        .quote-card {
            padding: clamp(1.8rem, 4vw, 3rem) clamp(1.5rem, 4vw, 3rem);
            border-radius: 28px;
            font-size: clamp(1.25rem, 2.8vw, 1.85rem);
            line-height: 1.4;
            color: #fff;
            font-weight: 500;
            max-width: 820px;
            margin-bottom: 2.5rem;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05);
        }

        .highlight {
            font-size: clamp(1.3rem, 3.2vw, 1.9rem);
            font-weight: 700;
            margin-bottom: 1.25rem;
            background: linear-gradient(90deg, #f472b6, #a78bfa, var(--blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1.3;
        }

        .purpose {
            max-width: 600px;
        }

        /* Pills */
        .pills {
            display: flex;
            gap: 0.85rem;
            flex-wrap: wrap;
            justify-content: center;
            margin: 2.5rem 0;
        }

        .pill {
            padding: 0.85rem 1.6rem;
            border-radius: 100px;
            font-size: 0.98rem;
            font-weight: 500;
            color: #e2e2ee;
            white-space: nowrap;
        }

        .bottom-line {
            font-size: 1.1rem;
            color: var(--text);
            margin-top: 0.5rem;
        }

        /* Fears */
        .fear-wrap {
            display: flex;
            align-items: center;
            gap: clamp(2rem, 6vw, 5rem);
            width: 100%;
            max-width: 1000px;
            text-align: left;
        }

        .big-num {
            font-family: 'Syne', sans-serif;
            font-size: clamp(5rem, 15vw, 11rem);
            font-weight: 800;
            line-height: 1;
            min-width: 220px;
            text-align: center;
            padding: 0 1rem;
            overflow: visible;
            -webkit-text-fill-color: transparent;
            -webkit-background-clip: text;
            background-clip: text;
            flex-shrink: 0;
        }

        .big-num.purple {
            background-image: linear-gradient(135deg, #8b5cf6 0%, #d946ef 100%);
        }
        .big-num.pink {
            background-image: linear-gradient(135deg, #ec4899 0%, #f43f5e 100%);
        }
        .big-num.blue {
            background-image: linear-gradient(135deg, #3b82f6 0%, #22d3ee 100%);
        }

        .fear-content {
            flex: 1;
            min-width: 0;
        }

        .fear-content p {
            margin: 0;
            font-size: clamp(1.05rem, 2.1vw, 1.25rem);
            color: var(--text);
            line-height: 1.5;
        }

        /* Closing */
        .closing p {
            font-size: clamp(1.1rem, 2.2vw, 1.3rem);
            color: var(--text);
            margin-bottom: 3rem;
        }

        .disclaimer {
            padding: 1.5rem 1.75rem;
            border-radius: 20px;
            text-align: left;
            max-width: 680px;
            margin: 0 auto 2.5rem;
        }

        .disclaimer label {
            display: block;
            font-size: 0.7rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--text-dim);
            font-weight: 600;
            margin-bottom: 0.6rem;
        }

        .disclaimer p {
            font-size: 0.95rem;
            line-height: 1.55;
            color: var(--text-dim);
            margin: 0;
        }

        footer {
            font-size: 0.85rem;
            color: var(--text-dim);
            opacity: 0.6;
            position: absolute;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
        }

        /* Mobile */
        @media (max-width: 768px) {
            .watermark {
                display: none;
            }
            
            section {
                padding: 1.5rem;
                height: 100dvh;
            }

            .snap {
                height: 100dvh;
            }

            .fear-wrap {
                flex-direction: column;
                text-align: center;
                gap: 1.5rem;
            }

            .big-num {
                min-width: auto;
                font-size: clamp(6rem, 28vw, 8rem);
                padding: 0;
            }

            .fear-content h3 {
                margin-bottom: 0.5rem;
            }

            .quote-card {
                border-radius: 20px;
            }

            .stats {
                gap: 0.75rem;
                flex-wrap: wrap;
            }
            
            .pills {
                gap: 0.6rem;
            }

            .pill {
                font-size: 0.9rem;
                padding: 0.75rem 1.3rem;
            }

            h1 {
                font-size: clamp(2.5rem, 12vw, 3.5rem);
            }

            .container {
                padding: 0 0.5rem;
            }
        }

        @media (max-height: 700px) {
            h1 { margin-bottom: 1rem; }
            .typewriter { margin-bottom: 1.5rem; }
            .stats { margin-bottom: 1.25rem; }
        }
    </style>
</head>
<body>
    <div class="bg">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
        <div class="blob blob-4"></div>
    </div>

    <div class="progress" id="progress"></div>
    <div class="watermark">scroll down</div>

    <main class="snap" id="snap">
        <!-- 1. HERO -->
        <section>
            <div class="container">
                <h1>Hey, I'm Chinju.</h1>
                <p class="typewriter" id="typewriter"></p>
                <div class="stats">
                    <div class="stat glass">13K+<span>views</span></div>
                    <div class="stat glass">80+<span>reactions</span></div>
                </div>
                <p class="tiny">Sharing with fellow UPSC aspirants what I've learned and what I'm still learning.</p>
            </div>
        </section>

        <!-- 2. THE QUESTION -->
        <section>
            <div class="container">
                <div class="quote-card glass">
                    "I want to start UPSC but I have zero idea. No coaching money. No guidance. Where do I even begin?"
                </div>
                <p class="highlight">My DMs were full of this one question.</p>
                <p class="purpose">That's why this page exists — to answer that exact question. No fluff, no sales pitch. Just a clear starting point for absolute beginners.</p>
            </div>
        </section>

        <!-- 3. START HERE -->
        <section>
            <div class="container">
                <h2>This is where we begin.</h2>
                <div class="pills">
                    <div class="pill glass">No coaching, no problem</div>
                    <div class="pill glass">No confusion allowed</div>
                    <div class="pill glass">Just you, your books</div>
                </div>
                <p class="bottom-line">+ If you can give at least 4 honest hours a day, that's enough.</p>
            </div>
        </section>

        <!-- 4. FEARS INTRO -->
        <section>
            <div class="container">
                <h2>3 fears that stop most beginners</h2>
                <p>Let's clear them in 30 seconds</p>
            </div>
        </section>

        <!-- 5. FEAR 01 -->
        <section>
            <div class="fear-wrap">
                <div class="big-num purple">01</div>
                <div class="fear-content">
                    <h3>I'm not from English medium / IIT / DU</h3>
                    <p>UPSC doesn't care about your college or accent. Toppers came from villages, Hindi-medium backgrounds, and families of daily-wage workers. It tests understanding, not background.</p>
                </div>
            </div>
        </section>

        <!-- 6. FEAR 02 -->
        <section>
            <div class="fear-wrap">
                <div class="big-num pink">02</div>
                <div class="fear-content">
                    <h3>I need to study 15 hours a day</h3>
                    <p>You don't. 4–5 focused hours beat 15 distracted hours. Many toppers did it with a full-time job. Consistency > intensity.</p>
                </div>
            </div>
        </section>

        <!-- 7. FEAR 03 -->
        <section>
            <div class="fear-wrap">
                <div class="big-num blue">03</div>
                <div class="fear-content">
                    <h3>I need coaching or I'll fail</h3>
                    <p>Coaching gives structure, not selection. With AI tools, free YouTube videos + standard books + discipline = structure. Think about it.</p>
                </div>
            </div>
        </section>

        <!-- 8. CLOSING -->
        <section class="closing">
            <div class="container">
                <h2>Take a breath.</h2>
                <p>You're not late. You're not underqualified. You just need a starting point.</p>
                
                <div class="disclaimer glass">
                    <label>DISCLAIMER</label>
                    <p>Take ideas, test them with your personal plan. Learn from multiple sources. Use trial and error. Consider the ideas shared here as an open conversation, not a rulebook.</p>
                </div>
            <footer>Chinju | UPSC Notes</footer>
        </section>
    </main>

    <script>
        // Typewriter
        const text = "Posted my UPSC notes on social media — 13,000 people saw it.";
        const el = document.getElementById('typewriter');
        let i = 0;
        
        function type() {
            if (i < text.length) {
                el.textContent = text.slice(0, i + 1);
                i++;
                setTimeout(type, 32);
            }
        }
        window.addEventListener('load', () => setTimeout(type, 600));

        // Progress bar
        const snap = document.getElementById('snap');
        const progress = document.getElementById('progress');
        
        snap.addEventListener('scroll', () => {
            const scrolled = snap.scrollTop;
            const max = snap.scrollHeight - snap.clientHeight;
            const pct = (scrolled / max) * 100;
            progress.style.width = pct + '%';
        });

        // Hide watermark on last sections
        snap.addEventListener('scroll', () => {
            const watermark = document.querySelector('.watermark');
            const sectionIndex = Math.round(snap.scrollTop / window.innerHeight);
            watermark.style.opacity = sectionIndex >= 6 ? '0' : '0.5';
        });
    </script>
